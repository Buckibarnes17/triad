#!/usr/bin/env bash
# mock qwen CLI for Triad smoke tests — emits the JSON EVENT ARRAY shape
# (result carried by the last type=="result" event). Logs argv + prompt to
# $MOCK_LOG; fresh calls mint mock-qwen-<n> ids via $MOCK_COUNTERS.
set -euo pipefail
LOG="${MOCK_LOG:-/dev/null}"
CDIR="${MOCK_COUNTERS:-${TMPDIR:-/tmp}}"
{ echo "--- qwen"; printf 'ARG:%s\n' "$@"; } >> "$LOG"
[ "${1:-}" = --version ] && { echo "mock-qwen 0.0.0"; exit 0; }

resume=""; prompt=""
while [ $# -gt 0 ]; do
  case "$1" in
    -r) resume="$2"; shift 2 ;;
    -p) prompt="$2"; printf 'PROMPT:%s\n' "$2" >> "$LOG"; shift 2 ;;
    *) shift ;;
  esac
done
if [ -n "$resume" ]; then
  sid="$resume"
else
  n=$(cat "$CDIR/qwen.n" 2>/dev/null || echo 0); n=$((n+1)); echo "$n" > "$CDIR/qwen.n"
  sid="mock-qwen-$n"
fi
if [ "${MOCK_CHECKPOINT_JSON:-0}" = 1 ] && [[ "$prompt" == *"CONTEXT"*"CHECKPOINT"* ]]; then
  ckpt='{"goals":"preserve context","decisions":[{"decision":"use checkpoint","rationale":"bounded recovery"}],"blockers":"none","approvals_pending":"none","next_actions":["continue task"],"paths":["scripts/pair.sh"],"tests":"smoke passed"}'
  jq -n --arg sid "$sid" --arg r "$ckpt" \
    '[{type:"system"}, {type:"result", result:$r, session_id:$sid}]'
elif [ "${MOCK_USAGE:-0}" = 1 ]; then
  jq -n --arg sid "$sid" \
    '[{type:"system"}, {type:"tool_use"}, {type:"result", result:("mock-qwen-result " + $sid), session_id:$sid,
      usage:{input_tokens:600, cached_input_tokens:400, output_tokens:50, context_window:131072}}]'
else
  jq -n --arg sid "$sid" \
    '[{type:"system"}, {type:"result", result:("mock-qwen-result " + $sid), session_id:$sid}]'
fi
