#!/usr/bin/env bash
# mock claude CLI for Triad smoke tests — emits the single-JSON headless
# envelope. Logs every arg (one ARG: line each) + the prompt to $MOCK_LOG so
# tests can assert arg ordering and prompt integrity. Fresh calls mint
# mock-claude-<n> ids via a counter in $MOCK_COUNTERS; resume echoes the id back.
set -euo pipefail
LOG="${MOCK_LOG:-/dev/null}"
CDIR="${MOCK_COUNTERS:-${TMPDIR:-/tmp}}"
{ echo "--- claude"; printf 'ARG:%s\n' "$@"; } >> "$LOG"
[ "${1:-}" = --version ] && { echo "mock-claude 0.0.0"; exit 0; }

resume=""; prompt=""
while [ $# -gt 0 ]; do
  case "$1" in
    -p) prompt="$2"; printf 'PROMPT:%s\n' "$2" >> "$LOG"; shift 2 ;;
    --resume) resume="$2"; shift 2 ;;
    *) shift ;;
  esac
done
if [ -n "$resume" ]; then
  sid="$resume"
else
  n=$(cat "$CDIR/claude.n" 2>/dev/null || echo 0); n=$((n+1)); echo "$n" > "$CDIR/claude.n"
  sid="mock-claude-$n"
fi
result="mock-claude-result $sid"
if [ "${MOCK_CHECKPOINT_JSON:-0}" = 1 ] && [[ "$prompt" == *"CONTEXT"*"CHECKPOINT"* ]]; then
  result='{"goals":"preserve context","decisions":[{"decision":"use checkpoint","rationale":"bounded recovery"}],"blockers":"none","approvals_pending":"none","next_actions":["continue task"],"paths":["scripts/pair.sh"],"tests":"smoke passed"}'
fi
if [ "${MOCK_USAGE_HUGE:-0}" = 1 ]; then
  # cumulative spend masquerading as resident context — the engine must clamp
  # this to its estimator instead of trusting it (rollover-thrash regression)
  jq -n --arg sid "$sid" --arg result "$result" '{session_id: $sid, result: $result,
    usage:{iterations:[{input_tokens:5000000, cache_creation_input_tokens:0,
      cache_read_input_tokens:0, output_tokens:80}]}}'
elif [ "${MOCK_USAGE:-0}" = 1 ]; then
  jq -n --arg sid "$sid" --arg result "$result" '{session_id: $sid, result: $result,
    usage:{iterations:[{input_tokens:100, cache_creation_input_tokens:20,
      cache_read_input_tokens:800, output_tokens:80}]}}'
else
  jq -n --arg sid "$sid" --arg result "$result" '{session_id: $sid, result: $result}'
fi
